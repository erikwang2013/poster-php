# ===========================================
# poster-php Environment Configuration 环境变量配置
# ===========================================
# Copy this file to your project root and rename to .env
# 将此文件复制到项目根目录并重命名为 .env
# ===========================================

# ── Image Driver 图像驱动 ──
# Driver: auto | gd | imagick
POSTER_IMAGE_DRIVER=auto

# JPEG quality (0-100) / JPEG 输出质量
POSTER_IMAGE_QUALITY=90

# Custom font path (absolute path, leave empty for bundled) / 自定义字体路径（绝对路径，留空使用自带）
POSTER_IMAGE_FONT=

# ── Captcha 验证码 ──
# Storage driver: auto | file | session | redis / 存储驱动
POSTER_CAPTCHA_STORAGE=auto

# TTL in seconds / 验证码有效期（秒）
POSTER_CAPTCHA_TTL=300

# Max attempts per key / 同一 key 最大尝试次数
POSTER_CAPTCHA_MAX_ATTEMPTS=3

# Default difficulty: easy | medium | hard / 默认难度
POSTER_CAPTCHA_DEFAULT_DIFFICULTY=medium

# Tolerance / 验证容差
# Click: pixel radius / 点击容差（像素半径）
POSTER_CAPTCHA_TOLERANCE_CLICK=18
# Rotate: degrees / 旋转容差（角度）
POSTER_CAPTCHA_TOLERANCE_ROTATE=5
# Slider: pixels / 滑块容差（像素）
POSTER_CAPTCHA_TOLERANCE_SLIDER=4

# Redis (when storage=redis) / Redis 配置（storage=redis 时生效）
POSTER_CAPTCHA_REDIS_PREFIX=poster:captcha:
POSTER_CAPTCHA_REDIS_CONNECTION=default

# File (when storage=file) / 文件存储（storage=file 时生效）
# Leave empty for system temp dir / 留空=系统临时目录
POSTER_CAPTCHA_FILE_PATH=

# ── Poster 海报 ──
# Default canvas size (px) / 默认画布尺寸
POSTER_POSTER_DEFAULT_WIDTH=750
POSTER_POSTER_DEFAULT_HEIGHT=1334

# Custom font path (absolute path) / 自定义字体路径（绝对路径）
POSTER_POSTER_FONT=

# JPEG quality / JPEG 输出质量
POSTER_POSTER_JPEG_QUALITY=90

# PNG compression (0-9) / PNG 压缩级别
POSTER_POSTER_PNG_COMPRESSION=6
